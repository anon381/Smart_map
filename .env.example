# ==============================================================================
# SmartMap Unified Environment Configuration Example
# ==============================================================================

# --- Database (Neon Cloud / PostgreSQL + PostGIS) ---
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DB]?sslmode=require
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# --- AI Engine (Google Gemini) ---
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# --- Authentication (Neon Auth / Clerk) ---
# Obtain these from your Neon Auth / Clerk dashboard
CLERK_ISSUER_URL="https://your-issuer-url-here.clerk.accounts.dev"
CLERK_AUDIENCE="any"
JWT_SECRET="your_super_secret_key_here"

# --- Frontend / Client Configuration ---
# The URL where the backend API is reachable
VITE_API_URL="http://localhost:5002/api"

# --- Image Storage (Cloudinary) ---
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
