# Neon Cloud Database (PostgreSQL + PostGIS)
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DB]?sslmode=require
DATABASE_URL=postgresql://neondb_owner:[YOUR_NEON_PASSWORD]@ep-cool-bonus-a4cqfbzj-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# AI Engine Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Neon Auth / Clerk Configuration (Required for verifying users)
# Obtain these from your Neon Auth / Clerk dashboard
CLERK_ISSUER_URL=https://your-issuer-url-here.clerk.accounts.dev
CLERK_AUDIENCE=any
